// Instale a biblioteca: DFRobot_PAJ7620U2
#include <Wire.h>
#include "DFRobot_PAJ7620U2.h"

DFRobot_PAJ7620U2 paj;

#define SDA_PIN 4
#define SCL_PIN 5

void setup() {
  Serial.begin(115200);
  delay(1000);

  Wire.begin(SDA_PIN, SCL_PIN);

  Serial.println("Iniciando PAJ7620...");

  while (paj.begin() != 0) {
    Serial.println("Erro ao iniciar o sensor PAJ7620.");
    delay(1000);
  }

  Serial.println("Sensor PAJ7620 iniciado com sucesso!");
  paj.setGestureHighRate(true);
}

void loop() {
  DFRobot_PAJ7620U2::eGesture_t gesture = paj.getGesture();

  if (gesture != paj.eGestureNone) {
    switch (gesture) {
      case paj.eGestureRight:
        Serial.println("Movimento: DIREITA");
        break;

      case paj.eGestureLeft:
        Serial.println("Movimento: ESQUERDA");
        break;

      case paj.eGestureUp:
        Serial.println("Movimento: CIMA");
        break;

      case paj.eGestureDown:
        Serial.println("Movimento: BAIXO");
        break;

      case paj.eGestureForward:
        Serial.println("Movimento: APROXIMAR");
        break;

      case paj.eGestureBackward:
        Serial.println("Movimento: AFASTAR");
        break;

      case paj.eGestureClockwise:
        Serial.println("Movimento: HORÁRIO");
        break;

      case paj.eGestureAntiClockwise:
        Serial.println("Movimento: ANTI-HORÁRIO");
        break;

      case paj.eGestureWave:
        Serial.println("Movimento: ACENAR");
        break;

      default:
        Serial.println("Gesto desconhecido");
        break;
    }
  }

  delay(100);
}
