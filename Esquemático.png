#include <Wire.h>
#include "DFRobot_PAJ7620U2.h"

/*
  Sistema Interativo de Holograma Controlado por Gestos

  Hardware:
  - ESP32-C3 DevKit
  - Sensor PAJ7620

  Comunicação:
  - ESP32 <-> PAJ7620 via I2C

  Observação:
  Ajuste SDA_PIN e SCL_PIN conforme os pinos usados no esquemático.
*/

DFRobot_PAJ7620U2 paj;

// Altere estes pinos se o seu esquemático usar outros GPIOs.
#define SDA_PIN 4
#define SCL_PIN 5

void setup() {
  Serial.begin(115200);
  delay(1000);

  Wire.begin(SDA_PIN, SCL_PIN);

  Serial.println("Iniciando sensor PAJ7620...");

  while (paj.begin() != 0) {
    Serial.println("Erro ao iniciar o sensor PAJ7620. Verifique conexoes SDA, SCL, 3V3 e GND.");
    delay(1000);
  }

  Serial.println("Sensor PAJ7620 iniciado com sucesso!");
  paj.setGestureHighRate(true);
}

void loop() {
  DFRobot_PAJ7620U2::eGesture_t gesture = paj.getGesture();

  if (gesture != paj.eGestureNone) {
    switch (gesture) {
      case paj.eGestureRight:
        Serial.println("Movimento detectado: DIREITA");
        break;

      case paj.eGestureLeft:
        Serial.println("Movimento detectado: ESQUERDA");
        break;

      case paj.eGestureUp:
        Serial.println("Movimento detectado: CIMA");
        break;

      case paj.eGestureDown:
        Serial.println("Movimento detectado: BAIXO");
        break;

      case paj.eGestureForward:
        Serial.println("Movimento detectado: APROXIMAR");
        break;

      case paj.eGestureBackward:
        Serial.println("Movimento detectado: AFASTAR");
        break;

      case paj.eGestureClockwise:
        Serial.println("Movimento detectado: HORARIO");
        break;

      case paj.eGestureAntiClockwise:
        Serial.println("Movimento detectado: ANTI-HORARIO");
        break;

      case paj.eGestureWave:
        Serial.println("Movimento detectado: ACENAR");
        break;

      default:
        Serial.println("Gesto desconhecido");
        break;
    }
  }

  delay(100);
}
